# Paqet UI - Environment Variables Configuration
# Copy this file to .env and adjust values as needed
# DO NOT commit .env to git

# ===============================
# Panel Configuration
# ===============================

# Port the web panel listens on
PANEL_PORT=2053

# Base path for the panel
PANEL_PATH=/panel

# Host to bind to (0.0.0.0 for all interfaces)
PANEL_HOST=0.0.0.0

# ===============================
# Database Configuration
# ===============================

# Database file path
DB_PATH=~/.paqet-ui/paqet-ui.db

# Enable database cleanup on startup
DB_RESET=false

# ===============================
# Logging Configuration
# ===============================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log file path (empty = stdout only)
LOG_FILE=~/.paqet-ui/app.log

# Log format: json, text
LOG_FORMAT=text

# ===============================
# Security Configuration
# ===============================

# Enable HTTPS
ENABLE_HTTPS=false

# SSL certificate file path
SSL_CERT_FILE=

# SSL private key file path
SSL_KEY_FILE=

# Session timeout in seconds (default: 86400 = 24 hours)
SESSION_TIMEOUT=86400

# Session cookie secure flag (only send over HTTPS)
SESSION_SECURE=false

# Initial admin username
ADMIN_USERNAME=admin

# Initial admin password (change immediately!)
ADMIN_PASSWORD=admin

# ===============================
# Feature Flags
# ===============================

# Enable WebSocket real-time updates
ENABLE_WEBSOCKET=false

# Enable configuration templates
ENABLE_TEMPLATES=false

# Enable advanced statistics
ENABLE_STATS=false

# ===============================
# Paqet Integration
# ===============================

# Path to paqet binary
PAQET_BIN=/usr/local/bin/paqet

# Default paqet working directory
PAQET_WORKDIR=/tmp/paqet

# Auto-restart crashed configurations
PAQET_AUTO_RESTART=true

# Restart delay in seconds
PAQET_RESTART_DELAY=5

# ===============================
# Performance Configuration
# ===============================

# Max database connections
DB_MAX_CONNECTIONS=25

# Database connection timeout
DB_TIMEOUT=30s

# API request timeout
API_TIMEOUT=30s

# Enable request compression
ENABLE_COMPRESSION=true

# ===============================
# Backup Configuration
# ===============================

# Enable automatic backups
ENABLE_AUTO_BACKUP=false

# Backup interval in hours
BACKUP_INTERVAL=24

# Number of backups to keep
BACKUP_RETENTION=7

# Backup directory
BACKUP_DIR=~/.paqet-ui/backups

# ===============================
# Notification Configuration
# ===============================

# Enable email notifications
ENABLE_EMAIL=false

# SMTP host
EMAIL_HOST=smtp.gmail.com

# SMTP port
EMAIL_PORT=587

# SMTP username
EMAIL_USERNAME=

# SMTP password
EMAIL_PASSWORD=

# From email address
EMAIL_FROM=

# Notification email recipients
EMAIL_RECIPIENTS=

# ===============================
# Development/Debug
# ===============================

# Enable debug mode
DEBUG=false

# Enable profiling
ENABLE_PROFILING=false

# Profile port
PROFILE_PORT=6060

# Verbose logging
VERBOSE=false
